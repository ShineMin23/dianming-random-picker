# 复制为 .env.local 后再填写真实值

# sqlite 或 supabase
REGISTRATION_BACKEND=supabase

# 你的 Supabase 项目 URL，例如 https://abcd1234.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# 建议使用 Supabase Dashboard 里的 Secret key
SUPABASE_SECRET_KEY=sb_secret_xxx

# 可选，默认就是 registrations
SUPABASE_TABLE=registrations

# 管理后台口令，打开 /admin 时需要输入
ADMIN_TOKEN=replace-with-a-long-random-string
